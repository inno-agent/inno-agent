# review-webhook — Slice 3: webhook → Kafka producer
# Copy to .env and fill in values before running.

# HTTP server port
SERVER_PORT=8002

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=redpanda:9092

# Kafka topic (must match the consumer)
KAFKA_TOPIC=gitflame.events

# Auth header value the webhook sender must supply verbatim.
# Empty = auth disabled (dev/debug mode).
WEBHOOK_AUTHORIZATION=

# Name of the request header carrying the auth constant.
WEBHOOK_AUTH_HEADER=Authorization

# Name of the request header carrying the event type.
WEBHOOK_EVENT_HEADER=X-GitFlame-Event

# Name of the request header carrying the delivery ID.
WEBHOOK_DELIVERY_HEADER=X-GitFlame-Delivery
