# GitFlame API (read-only)
GITFLAME_BASE_URL=https://api.gitflame.ru
GITFLAME_TOKEN=

# Direct Ollama access (bypasses orchestrator + arch-router).
# Production: http://ollama:11434 (or remote GPU URL)
# If empty, falls back to ORCHESTRATOR_URL.
OLLAMA_BASE_URL=

# Orchestrator fallback (used when OLLAMA_BASE_URL is empty)
ORCHESTRATOR_URL=http://orchestrator:8080

# Exec sandbox (build/test/lint). Bearer SANDBOX_TOKEN must match the sandbox service.
SANDBOX_URL=http://sandbox:8080
SANDBOX_TOKEN=

# Model for reviews
# Production: qwen2.5-coder-32b (remote GPU, 80GB RAM)
# Default: qwen2.5-coder:1.5b (works out-of-box via orchestrator)
REVIEW_MODEL=qwen2.5-coder:1.5b

# Auth token for /review endpoint
# If empty, all requests are rejected (503)
REVIEW_AGENT_AUTH_TOKEN=

# Rate limiting: max concurrent reviews (default 4)
MAX_CONCURRENT_REVIEWS=4

# Chunking: tokens per chunk for investigate step (default 12000)
CHUNK_TOKEN_BUDGET=12000

# Parallel chunks: concurrent LLM calls per batch (default 3)
CONCURRENT_CHUNKS=3

# Cache TTL in ms (default 1 hour)
CACHE_TTL_MS=3600000

# Review timeout in ms (default 5 minutes)
REVIEW_TIMEOUT_MS=300000

# Server
SERVER_PORT=4100
