# GitFlame API (read-only)
GITFLAME_BASE_URL=https://api.gitflame.ru
GITFLAME_TOKEN=

# Orchestrator (OpenAI-compatible endpoint)
ORCHESTRATOR_URL=http://orchestrator:8080

# Model for reviews
# Production: qwen2.5-coder-32b (remote GPU, 80GB RAM)
# Local dev: use --profile local with smaller model
REVIEW_MODEL=qwen2.5-coder-32b

# Auth token for /review endpoint
# If empty, all requests are rejected (503)
REVIEW_AGENT_AUTH_TOKEN=

# Server
SERVER_PORT=4100
