KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=gitflame.events
KAFKA_GROUP=issue-consumer
ORCHESTRATOR_TOKEN=
GITFLAME_BASE_URL=
GITFLAME_TOKEN=

BOT_GITFLAME_USERNAME=
IDENTITY_URL=http://identity:8081
REVIEW_SERVICE_CLIENT_ID=review-consumer
REVIEW_SERVICE_CLIENT_SECRET=
ONBOARDING_URL=

# Codegen agent (Mastra) — REQUIRED. URL of the review-agent service's /codegen
# endpoint; the single-shot generator has been removed, so this must be set.
# The agent runs the agentic loop and carries the issue author's delegated token
# to the orchestrator (per-user attribution + onboarding gate). The codegen model
# itself is chosen by the agent via its own CODEGEN_MODEL env, not here.
CODEGEN_AGENT_URL=http://review-agent:4100
# Shared secret for the codegen endpoint. Must match REVIEW_AGENT_AUTH_TOKEN
# in the review-agent service.
CODEGEN_AGENT_AUTH_TOKEN=
