# Models served/validated. First entry is the default (fallback when a request
# omits the model). Light models for local dev.
LLM_MODELS=qwen2.5:0.5b llama3.2:1b qwen2.5-coder:1.5b

# Ollama service connection (used inside Docker network)
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# Port exposed by the orchestrator on the host
API_PORT=8080

# Full base URL override (optional — auto-built from OLLAMA_HOST + OLLAMA_PORT if not set)
# LLM_BASE_URL=http://ollama:11434/v1
