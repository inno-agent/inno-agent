{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "icon": "dashboard", "keepTime": true, "title": "Service Overview", "type": "link", "url": "/d/inno-service-overview" }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "pg_stat_database_numbackends{env=~\"$env\", service=~\"$service\"}", "legendFormat": "{{datname}}", "refId": "A" }],
      "title": "Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "pg_database_size_bytes{env=~\"$env\", service=~\"$service\"}", "legendFormat": "{{datname}}", "refId": "A" }],
      "title": "DB size",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (datname) (rate(pg_stat_database_blks_hit{env=~\"$env\", service=~\"$service\"}[5m])) / (sum by (datname) (rate(pg_stat_database_blks_hit{env=~\"$env\", service=~\"$service\"}[5m])) + sum by (datname) (rate(pg_stat_database_blks_read{env=~\"$env\", service=~\"$service\"}[5m])))", "legendFormat": "{{datname}}", "refId": "A" }],
      "title": "Cache hit ratio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{env=~\"$env\", service=~\"$service\"}[5m]))", "legendFormat": "commit {{datname}}", "refId": "A" }],
      "title": "Transactions commit",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{env=~\"$env\", service=~\"$service\"}[5m]))", "legendFormat": "rollback {{datname}}", "refId": "A" }],
      "title": "Transactions rollback",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 40,
  "tags": ["postgres", "infra"],
  "templating": {
    "list": [
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "includeAll": true,
        "allValue": ".*",
        "label": "env",
        "multi": true,
        "name": "env",
        "query": { "query": "label_values(probe_success, env)", "refId": "A" },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "text": "postgres", "value": "postgres" },
        "hide": 2,
        "label": "service",
        "name": "service",
        "query": "postgres",
        "type": "constant"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Postgres Overview",
  "uid": "inno-postgres-overview",
  "version": 2
}
