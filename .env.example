# =============================================================
# Root .env — используется docker-compose.yml в корне проекта.
# Скопируй в .env и заполни значения перед первым запуском.
#
# ⚠️  AUTHENTIK_ADMIN_PASSWORD применяется только при первом старте
#     (bootstrap пользователя akadmin). Чтобы пересоздать всё с нуля —
#     `docker compose down -v`.
# =============================================================

# -----------------------------
# Домен / внешний адрес
# -----------------------------
# Домен или IP сервера. На локалке — localhost.
AUTH_DOMAIN=localhost
# Внешний порт authentik (nginx, TLS self-signed).
AUTH_PORT=8080
AUTH_SCHEME=https
# Схема приложения. Влияет на redirect_uri в authentik blueprint.
APP_SCHEME=https

# -----------------------------
# Authentik
# -----------------------------
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server:2025.6
# Сгенерировать: openssl rand -base64 48
AUTHENTIK_SECRET_KEY=change-me-openssl-rand-base64-48
# Пароль пользователя akadmin (применяется при первом старте)
AUTHENTIK_ADMIN_PASSWORD=change-me

# -----------------------------
# SMTP (authentik, опционально — для писем восстановления пароля и т.п.)
# -----------------------------
AUTHENTIK_EMAIL__HOST=smtp.example.com
AUTHENTIK_EMAIL__PORT=465
AUTHENTIK_EMAIL__USERNAME=noreply@example.com
AUTHENTIK_EMAIL__PASSWORD=your-smtp-password
AUTHENTIK_EMAIL__USE_SSL=true
AUTHENTIK_EMAIL__FROM=noreply@example.com

# -----------------------------
# PostgreSQL
# -----------------------------
# Основная БД — authentik; inno_auth и llm_chat создаются init-скриптами.
POSTGRES_DB=authentik
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres

# -----------------------------
# Identity service
# -----------------------------
# OIDC_* переменные identity-сервиса задаются в docker-compose.yml
# из AUTH_SCHEME/AUTH_DOMAIN/AUTH_PORT — здесь дублировать не нужно.
AUTH_DATABASE_DSN=postgresql://postgres:postgres@postgres:5432/inno_auth?sslmode=disable

# -----------------------------
# AI / LLM
# -----------------------------
MODEL_NAME=qwen2.5:0.5b

# -----------------------------
# Версии образов
# -----------------------------
POSTGRES_IMAGE=postgres:17.2-alpine
REDIS_IMAGE=redis:7-alpine
