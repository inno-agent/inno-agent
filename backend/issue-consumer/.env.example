KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=gitflame.events
KAFKA_GROUP=issue-consumer
ORCHESTRATOR_URL=http://orchestrator:8080
ORCHESTRATOR_TOKEN=
CODEGEN_MODEL=qwen2.5-coder:1.5b
GITFLAME_BASE_URL=
GITFLAME_TOKEN=

BOT_GITFLAME_USERNAME=
IDENTITY_URL=http://identity:8081
REVIEW_SERVICE_CLIENT_ID=review-consumer
REVIEW_SERVICE_CLIENT_SECRET=
ONBOARDING_URL=

# Codegen Agent (Mastra) - optional, falls back to single-shot LLM if not set
# URL of the Mastra codegen agent service (same review-agent service, /codegen endpoint).
# Example: http://review-agent:4100
# NOTE: enabling this changes the LLM call's token model. The single-shot
# fallback attaches a delegated RFC 8693 user token (via IDENTITY_URL /
# REVIEW_SERVICE_CLIENT_*) to every orchestrator call. The Mastra agent calls
# Ollama directly with no per-user token. See internal/config/config.go for
# details before enabling in an environment that requires per-user LLM
# attribution/quota.
CODEGEN_AGENT_URL=
# Shared secret for the codegen endpoint. Must match REVIEW_AGENT_AUTH_TOKEN
# in the review-agent service.
CODEGEN_AGENT_AUTH_TOKEN=
