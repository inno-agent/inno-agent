# =============================================================
# infrastructure/.env — используется infrastructure/docker-compose.yml
# (инфра-стек без фронтенда и бэкенда).
# Скопируй в .env и заполни значения перед первым запуском.
#
# ⚠️  Переменные с пометкой "set once" записываются в БД
#     при первом старте и игнорируются при последующих.
#     Чтобы изменить их — сделай `docker compose down -v`.
# =============================================================

# -----------------------------
# Домен / внешний адрес
# -----------------------------
# IP-адрес или домен сервера. На локалке — localhost.
ZITADEL_DOMAIN=localhost
ZITADEL_EXTERNALDOMAIN=localhost
PROXY_HTTP_PUBLISHED_PORT=8080
ZITADEL_EXTERNALPORT=8080
# false = plain HTTP (локалка), true = HTTPS за reverse proxy (прод)
ZITADEL_EXTERNALSECURE=false
ZITADEL_PUBLIC_SCHEME=http

# Схема приложения (http/https). Влияет на redirect_uri в Zitadel.
# На сервере без домена: https (Traefik генерирует self-signed cert).
# На локалке: http (localhost — secure context, crypto.subtle работает).
APP_SCHEME=http

# -----------------------------
# Безопасность  ⚠️  set once
# Мастер-ключ должен быть ровно 32 символа. Сгенерировать:
#   openssl rand -base64 24 | tr -d '=' | head -c 32
# -----------------------------
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# -----------------------------
# Zitadel admin  ⚠️  set once
# -----------------------------
ZITADEL_ADMIN_PASSWORD=Admin1234!

# -----------------------------
# SMTP  ⚠️  set once
# ВАЖНО: Zitadel v4 принимает SMTP-конфигурацию только через YAML (PlainAuth).
# Через env vars credentials не сохраняются.
# -----------------------------
ZITADEL_SMTP_DESCRIPTION=My SMTP Provider
ZITADEL_SMTP_HOST=smtp.example.com:465
ZITADEL_SMTP_TLS=true
ZITADEL_SMTP_FROM=noreply@example.com
ZITADEL_SMTP_FROM_NAME=My App
ZITADEL_SMTP_USER=noreply@example.com
ZITADEL_SMTP_PASSWORD=your-smtp-password

# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_DB=zitadel
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/zitadel?sslmode=disable

# -----------------------------
# Auth service
# -----------------------------
# ZITADEL_ISSUER вычисляется автоматически из ZITADEL_PUBLIC_SCHEME +
# ZITADEL_DOMAIN + ZITADEL_EXTERNALPORT и передаётся через environment:.
# Указывать здесь не обязательно — значение всё равно будет перезаписано.
AUTH_DATABASE_DSN=postgresql://postgres:postgres@postgres:5432/inno_auth?sslmode=disable

# -----------------------------
# Версии образов
# -----------------------------
ZITADEL_VERSION=v4.15.0
TRAEFIK_IMAGE=traefik:v3.7.4
POSTGRES_IMAGE=postgres:17.2-alpine

# -----------------------------
# Внутреннее (не менять без необходимости)
# -----------------------------
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z
