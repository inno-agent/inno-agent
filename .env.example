# =============================================================
# Root .env — используется docker-compose.yml в корне проекта.
# Скопируй в .env и заполни значения перед первым запуском.
#
# ⚠️  AUTHENTIK_ADMIN_PASSWORD применяется только при первом старте
#     (bootstrap пользователя akadmin). Чтобы пересоздать всё с нуля —
#     `docker compose down -v`.
# =============================================================

# -----------------------------
# Домен / внешний адрес
# -----------------------------
# Хост сервера (домен или голый IP) — используется как server_name корневого
# (chat) вирт-хоста и в Grafana ROOT_URL. На локалке — localhost.
# Authentik и review — свои порты (9443 / 8443) на том же хосте, не
# поддомены: так это работает и без DNS, на голом IP тоже.
AUTH_DOMAIN=localhost

# Полный внешний URL, на котором реально висит Authentik (issuer в JWT
# identity должен буквально совпадать с тем, что видит браузер/токен).
# Authentik — на дефолтном порту (443), поэтому без порта и без поддомена.
# На проде — https://<AUTH_DOMAIN>
AUTH_ISSUER_URL=https://localhost

# OAuth2 redirect_uri для чат-приложения и ревьюера (authentik blueprint).
# Локально — свои поддомены (chat./review.) для читаемости; на голом IP
# (прод) поддоменов нет физически, там только порт различает сервисы:
# https://<AUTH_DOMAIN>:9443/callback и https://<AUTH_DOMAIN>:8443/callback
APP_CALLBACK_URL=https://chat.localhost:9443/callback
REVIEW_CALLBACK_URL=https://review.localhost:8443/callback

# -----------------------------
# Authentik
# -----------------------------
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server:2025.6
# Сгенерировать: openssl rand -base64 48
AUTHENTIK_SECRET_KEY=change-me-openssl-rand-base64-48
# Пароль пользователя akadmin (применяется при первом старте)
AUTHENTIK_ADMIN_PASSWORD=change-me

# -----------------------------
# SMTP (authentik) — ОБЯЗАТЕЛЬНО для саморегистрации:
# аккаунт активируется письмом-подтверждением. Без SMTP новые
# пользователи останутся неактивными.
# -----------------------------
AUTHENTIK_EMAIL__HOST=smtp.example.com
AUTHENTIK_EMAIL__PORT=465
AUTHENTIK_EMAIL__USERNAME=noreply@example.com
AUTHENTIK_EMAIL__PASSWORD=your-smtp-password
AUTHENTIK_EMAIL__USE_SSL=true
AUTHENTIK_EMAIL__FROM=noreply@example.com

# -----------------------------
# PostgreSQL
# -----------------------------
# Основная БД — authentik; inno_auth, llm_chat и inno_review создаются
# init-скриптом вместе с выделенными ролями (authentik / identity / chat /
# review) при ПЕРВОМ старте.
# Изменение паролей ролей после первого старта требует `docker compose down -v`.
POSTGRES_DB=authentik
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
AUTHENTIK_PG_PASSWORD=change-me
IDENTITY_PG_PASSWORD=change-me
CHAT_PG_PASSWORD=change-me
REVIEW_PG_PASSWORD=change-me

# -----------------------------
# Identity service
# -----------------------------
AUTH_DATABASE_DSN=postgresql://postgres:postgres@postgres:5432/inno_auth?sslmode=disable

# -----------------------------
# AI / LLM
# -----------------------------
# Список моделей: тянутся в ollama, валидируются и предлагаются в выборе.
# Первая в списке — модель по умолчанию (fallback, если в запросе не указана).
# Лёгкие модели для локалки.
LLM_MODELS=qwen2.5:0.5b llama3.2:1b qwen2.5-coder:1.5b
# Модель-маршрутизатор для "auto" режима. Она анализирует запрос и выбирает
# наиболее подходящую модель из LLM_MODELS.
ROUTER_MODEL=fauxpaslife/arch-router:1.5b

# Remote Ollama URL.  Leave empty for local Ollama (http://ollama:11434).
# OLLAMA_BASE_URL=https://gpu-0.devops-playground.innopolis.university
# Bearer token for the reverse proxy.  Leave empty for local Ollama.
# OLLAMA_API_KEY=
# Max retries for transient errors (default 3).
# OLLAMA_RETRY_MAX=3

# -----------------------------
# Ollama parallel / queue
# -----------------------------
OLLAMA_NUM_PARALLEL=6
OLLAMA_MAX_LOADED_MODELS=4
OLLAMA_MAX_QUEUE=2048

# -----------------------------
# Ollama run-time performance tuning
# -----------------------------
# Enables Flash Attention (speeds up inference on compatible GPUs)
OLLAMA_FLASH_ATTENTION=1
# Enables CUDA GPU acceleration (required for Nvidia GPUs)
OLLAMA_CUDA=1
# Reduces VRAM usage by quantizing the KV cache (q8_0 balances speed/memory)
OLLAMA_KV_CACHE_TYPE=q8_0

# -----------------------------
# Review API / GitFlame
# -----------------------------
# GitFlame instance URL (e.g. https://gitflame.example.com)
GITFLAME_BASE_URL=https://api.gitflame.ru
# Personal access token with read:pull_request scope
GITFLAME_TOKEN=
# -----------------------------

# -----------------------------
# Review bot (service credentials auth + RFC 8693 token exchange)
# -----------------------------
# DSN for the shared inno_review DB (review-api writes installations,
# review-consumer reads user_id for RFC 8693 delegate token exchange).
REVIEW_DATABASE_DSN=postgresql://review:change-me@postgres:5432/inno_review?sslmode=disable
# Client credentials for review-consumer. Identity issues a service JWT, then
# exchanges it for a per-user delegated JWT (sub=user_id) via /identity/v1/token.
# The identity service seeds this client at startup (via SEED_CLIENT_ID/SECRET).
# Production: set a strong randomly-generated secret.
REVIEW_SERVICE_CLIENT_ID=review-consumer
REVIEW_SERVICE_CLIENT_SECRET=
# GitFlame account of the bot; the consumer reviews only when THIS user is the
# requested reviewer on a PR.
BOT_GITFLAME_USERNAME=Innoagent
# Public URL shown in the "connect your account" comment for un-onboarded
# assigners (e.g. https://review.localhost:8443 locally, https://<AUTH_DOMAIN>:8443 on prod).
ONBOARDING_URL=
# -----------------------------

# -----------------------------
# Review bot webhook (slice 3)
# -----------------------------
# Constant token the repo owner pastes into GitFlame's auth-header field.
# The review-webhook service compares every incoming request header against
# this value (ConstantTimeCompare). Empty = auth disabled (dev mode).
WEBHOOK_AUTHORIZATION=
# -----------------------------

# -----------------------------
# Версии образов
# -----------------------------
POSTGRES_IMAGE=postgres:17.2-alpine
REDIS_IMAGE=redis:7-alpine
NGINX_IMAGE=nginx:alpine

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Loki
LOKI_RETENTION_PERIOD=720h

# Promtail
PROMTAIL_SCRAPE_INTERVAL=5s

# Alertmanager / Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
